# airline-sked 환경 설정

# Database
DATABASE_URL=sqlite+aiosqlite:///data/airline_sked.db

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id

# Scraping
SCRAPE_INTERVAL_HOURS=24
SCRAPE_USER_AGENT=airline-sked/0.1 (schedule-monitor)
SCRAPE_REQUEST_DELAY_SEC=2

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
